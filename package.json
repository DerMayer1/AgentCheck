{
  "name": "agentcheck",
  "version": "0.0.0",
  "description": "Evidence-first repository readiness checks for AI coding agents.",
  "type": "module",
  "bin": {
    "agentcheck": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "npm@10.9.4",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.8",
    "ajv": "^8.17.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
